{
  "name": "@grit42/client-library",
  "license": "GPL-3.0-or-later",
  "author": "Jonathan Rebourt, grit42 <jonny@grit42.com>",
  "repository": "https://github.com/grit42/grit",
  "version": "0.8.0",
  "type": "module",
  "exports": {
    "./theme.scss": {
      "import": "./dist/scss/theme.scss"
    },
    "./mixins.scss": {
      "import": "./dist/scss/mixins.scss"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "COPYING"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "tsc": "tsc -b",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier . -w --ignore-path ../../../.prettierignore",
    "format:check": "prettier . -c --ignore-path ../../../.prettierignore",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-externalize-deps": "catalog:",
    "vite-plugin-lib-inject-css": "catalog:",
    "vite-plugin-static-copy": "catalog:"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.28",
    "dayjs": "^1.11.19",
    "react-dropzone": "^14.4.1",
    "react-tabs": "^6.1.0",
    "superjson": "^2.2.6"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  }
}
