{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "source": [
      "{projectRoot}/src/**/*",
      "{projectRoot}/lib/**/*",
      "{projectRoot}/app/**/*",
      "{projectRoot}/config/**/*",
      "{projectRoot}/db/**/*"
    ],
    "testSource": ["{projectRoot}/test/**/*"],
    "lintable": [
      "{projectRoot}/**/*.{ts,tsx,js,jsx,rb}",
      "{projectRoot}/eslint.config.*",
      "{projectRoot}/.rubocop.yml"
    ],
    "formattable": [
      "{projectRoot}/**/*.{ts,tsx,js,jsx,json,scss,css,md}",
      "{workspaceRoot}/.prettierrc.json"
    ],
    "rubySource": [
      "{projectRoot}/app/**/*",
      "{projectRoot}/lib/**/*",
      "{projectRoot}/config/**/*",
      "{projectRoot}/db/**/*"
    ],
    "rubyTest": ["{projectRoot}/test/**/*", "{projectRoot}/spec/**/*"],
    "rubyLintable": ["{projectRoot}/**/*.rb", "{projectRoot}/.rubocop.yml"]
  },
  "targetDefaults": {
    "dev": {
      "continuous": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["source"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "format:check": {
      "inputs": ["formattable"],
      "cache": true
    },
    "format": {
      "inputs": ["formattable"]
    },
    "typecheck": {
      "inputs": ["source"],
      "cache": true
    },
    "lint:check": {
      "inputs": ["lintable"],
      "cache": true
    },
    "lint": {
      "inputs": ["lintable"]
    },
    "test": {
      "inputs": ["source", "testSource"],
      "cache": true
    }
  },
  "plugins": [
    "./tools/ruby/src/index.ts",
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildTargetName": "vite:build",
        "devTargetName": "vite:dev",
        "previewTargetName": "preview",
        "serveStaticTargetName": "serve-static",
        "typecheckTargetName": "typecheck"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "eslint"
      }
    }
  ],
  "release": {
    "versionPlans": true,
    "changelog": {
      "projectChangelogs": {
        "renderOptions": {
          "authors": false,
          "applyUsernameToAuthors": false,
          "commitReferences": false,
          "versionTitleDate": false
        }
      }
    },
    "git": {
      "tag": false
    },
    "version": {
      "updateDependents": "never"
    },
    "projectsRelationship": "independent",
    "groups": {
      "lib": {
        "projects": [
          "@grit42/notifications",
          "@grit42/client-library",
          "@grit42/form",
          "@grit42/api",
          "@grit42/table",
          "@grit42/spreadsheet",
          "@grit42/plots"
        ]
      },
      "core": {
        "projects": ["grit-core", "@grit42/core"]
      },
      "compounds": {
        "projects": ["grit-compounds", "@grit42/compounds"]
      },
      "assays": {
        "projects": ["grit-assays", "@grit42/assays"]
      }
    }
  }
}
