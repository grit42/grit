{
  "implicitDependencies": ["grit-core"],
  "targets": {
    "dev": {
      "dependsOn": [
        {
          "dependencies": true,
          "target": "build"
        },
        {
          "projects": ["grit-core"],
          "target": "serve"
        }
      ]
    },
    "serve:test": {
      "command": "pnpm vite --port 3001",
      "continuous": true,
      "options": {
        "cwd": "modules/core/frontend"
      },
      "dependsOn": [
        {
          "dependencies": true,
          "target": "build"
        },
        {
          "projects": ["grit-core"],
          "target": "serve:test"
        }
      ]
    },
    "test": {
      "dependsOn": [
        {
          "projects": ["grit-core"],
          "target": "serve:test"
        }
      ]
    },
    "test:e2e": {
      "command": "pnpm playwright test",
      "options": {
        "cwd": "modules/core/frontend"
      },
      "dependsOn": [
        {
          "target": "serve:test"
        }
      ]
    }
  }
}
