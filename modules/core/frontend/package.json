{
  "name": "@grit42/core",
  "author": "Jonathan Rebourt, grit42 <jonny@grit42.com>",
  "license": "GPL-3.0-or-later",
  "version": "0.10.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "COPYING"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": "https://github.com/grit42/grit.git",
  "scripts": {
    "dev": "vite --port 3001",
    "tsc": "tsc -b",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier . -w --ignore-path ../../../.prettierignore",
    "format:check": "prettier . -c --ignore-path ../../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@grit42/api": "workspace:*",
    "@grit42/client-library": "workspace:*",
    "@grit42/form": "workspace:*",
    "@grit42/notifications": "workspace:*",
    "@grit42/spreadsheet": "workspace:*",
    "@grit42/table": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "axios": "catalog:",
    "dayjs": "^1.11.19",
    "monaco-editor": "^0.52.2",
    "papaparse": "^5.5.3",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@playwright/test": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/papaparse": "^5.5.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "happy-dom": "^20.8.3",
    "path": "^0.12.7",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-externalize-deps": "catalog:",
    "vite-plugin-lib-inject-css": "catalog:",
    "vitest": "catalog:"
  }
}
