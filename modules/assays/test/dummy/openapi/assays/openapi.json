{
  "openapi": "3.0.1",
  "info": {
    "title": "Grit Assays API",
    "version": "v1",
    "description": "Assays module API — assay models, experiments, data sheets, and data tables."
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Module dev server"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookie_auth": {
        "type": "apiKey",
        "name": "_grit_session",
        "in": "cookie"
      },
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token (single_access_token). Generate via POST /api/grit/core/user/generate_api_token"
      }
    }
  },
  "security": [
    {
      "cookie_auth": []
    },
    {
      "bearer_auth": []
    }
  ],
  "paths": {
    "/api/grit/assays/assay_data_sheet_columns": {
      "get": {
        "summary": "Lists all assay data sheet columns",
        "tags": [
          "Assays - Assay Data Sheet Columns"
        ],
        "security": [
          {
            "cookie_auth": []
          }
        ],
        "responses": {
          "200": {
            "description": "assay data sheet columns listed"
          }
        }
      },
      "post": {
        "summary": "Creates an assay data sheet column",
        "tags": [
          "Assays - Assay Data Sheet Columns"
        ],
        "security": [
          {
            "cookie_auth": []
          }
        ],
        "parameters": [],
        "responses": {
          "201": {
            "description": "column created on draft model"
          },
          "500": {
            "description": "cannot create column on published model"
          },
          "422": {
            "description": "cannot create column with invalid safe_name"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/api/grit/assays/assay_data_sheet_columns/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "get": {
        "summary": "Shows an assay data sheet column",
        "tags": [
          "Assays - Assay Data Sheet Columns"
        ],
        "security": [
          {
            "cookie_auth": []
          }
        ],
        "responses": {
          "200": {
            "description": "assay data sheet column shown"
          }
        }
      },
      "patch": {
        "summary": "Updates an assay data sheet column",
        "tags": [
          "Assays - Assay Data Sheet Columns"
        ],
        "security": [
          {
            "cookie_auth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "column updated on draft model"
          },
          "500": {
            "description": "cannot update column on published model"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Destroys an assay data sheet column on draft model",
        "tags": [
          "Assays - Assay Data Sheet Columns"
        ],
        "security": [
          {
            "cookie_auth": []
          }
        ],
        "responses": {
          "200": {
            "description": "column destroyed"
          }
        }
      }
    },
